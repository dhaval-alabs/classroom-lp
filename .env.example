# ── AnalytixLabs Classroom Landing Page — environment ───────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Supabase (lead storage) ---
# Server-only service-role key is used by /api/lead to insert leads (bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=            # https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=                # service_role key (SERVER ONLY — never expose to the client)

# --- Gemini (lead qualification chatbot + scoring) ---
# When unset, the qualification chat still runs but skips AI acks/scoring.
GEMINI_API_KEY=                      # Google Gemini API key (aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash        # optional; code defaults to gemini-2.5-flash

# --- Conversion tracking (all optional; tags are skipped if blank) ---
# Meta (Facebook) Pixel — fires PageView on load + Lead on successful submit.
NEXT_PUBLIC_META_PIXEL_ID=

# Google Ads — gtag config id (AW-XXXXXXXXX) + the conversion label for a lead.
NEXT_PUBLIC_GOOGLE_ADS_ID=           # e.g. AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=   # e.g. AbC-D_efGhIjKlmNoP (from the conversion action)

# Google Analytics 4 — fires page_view + a generate_lead event.
NEXT_PUBLIC_GA4_ID=                  # e.g. G-XXXXXXXXXX

# --- Contact details shown on the page (used in header / footer / FAB) ---
NEXT_PUBLIC_CONTACT_PHONE=+91 95552 17077
NEXT_PUBLIC_WHATSAPP_NUMBER=919555217077
NEXT_PUBLIC_SITE_URL=http://localhost:3000
