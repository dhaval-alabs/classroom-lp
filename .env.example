# ── AnalytixLabs Classroom Landing Page — environment ───────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Supabase (lead storage) ---
# This app is isolated in its own schema (`classroom_landingpage`) inside a
# shared Supabase project. After running the migrations, expose the schema:
# Supabase → Settings → API → "Exposed schemas" → add `classroom_landingpage`.
NEXT_PUBLIC_SUPABASE_URL=                  # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=      # sb_publishable_… (browser-safe anon key)
SUPABASE_SECRET_KEY=                       # sb_secret_… (SERVER ONLY, bypasses RLS)
# Direct Postgres via the dedicated app role (pg Pool). Get <POOLER_HOST> from
# Supabase → Settings → Database → Session pooler (port 6543).
CLASSROOM_LANDINGPAGE_DB_URL=              # postgres://lp_classroom_landingpage:<LP_PASSWORD>@<POOLER_HOST>:6543/postgres

# --- LeadSquared CRM (optional; skipped if LSQ_ACCESS/LSQ_SECRET blank) ---
LSQ_ACCESS=                          # LeadSquared access key
LSQ_SECRET=                          # LeadSquared secret key
LSQ_HOST=api-in21.leadsquared.com    # your LSQ region/host
LSQ_LEAD_SCORE_FIELD=mx_Lead_Score   # schema name of the lead-score field
LSQ_NOTES_FIELD_NAME=mx_Extra_Notes  # schema name of the notes field (course/city/etc go here)
LSQ_FBCLID_FIELD=mx_FBCLID           # schema name of the Meta click-id field
LSQ_CHAT_FIELD=mx_Chat_Transcript    # schema name of the Gemini transcript field
LSQ_PAGE_URL_FIELD=mx_Page_Url       # schema name of the landing-page URL field (also in Notes)
# LSQ_VERIFIED_FIELD=mx_Lead_Verified # Verified/Unverified flag (chat completed vs form only).
#   Also always in Notes as "Status: …". Create the field in LSQ (Text, or Select
#   with exactly "Verified" + "Unverified") and it starts flowing automatically.
# The app fetches the account's field list and drops any attribute whose schema
# name doesn't exist before sending, so a wrong name here logs a warning instead
# of rejecting the whole lead. Still, point each var at a REAL field to keep the data.
# OPTIONAL extra dedicated columns — create the field in LSQ first, then set:
# LSQ_COURSE_FIELD=mx_Course_Suggested   # NOTE: Select-type fields reject values that aren't preset options
# LSQ_CITY_FIELD=mx_City
# LSQ_BACKGROUND_FIELD=mx_Lead_Profile

# --- Gemini (lead qualification chatbot + scoring) ---
# When unset, the qualification chat still runs but skips AI acks/scoring.
GEMINI_API_KEY=                      # Google Gemini API key (aistudio.google.com/apikey)
GEMINI_MODEL=gemini-3.5-flash        # optional; code defaults to gemini-3.5-flash

# --- Conversion tracking (all optional; tags are skipped if blank) ---
# Meta Pixel (browser) — fires PageView on load + Lead on successful submit.
NEXT_PUBLIC_META_PIXEL_ID=            # 15-16 digit id from Meta Events Manager
# Meta Conversions API (server-side Lead, deduped with the pixel via event_id).
# Events Manager → Dataset → Settings → Conversions API → Generate access token.
# When blank, server-side CAPI is skipped (browser pixel still works).
META_CAPI_ACCESS_TOKEN=              # EAA… long-lived token (SERVER ONLY, secret)
META_TEST_EVENT_CODE=               # set ONLY while testing (Events Manager → Test Events); blank in prod

# Google Ads — gtag config id (AW-XXXXXXXXX) + the conversion label for a lead.
NEXT_PUBLIC_GOOGLE_ADS_ID=           # e.g. AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=   # e.g. AbC-D_efGhIjKlmNoP (from the conversion action)

# Google Analytics 4 — fires page_view + a generate_lead event.
NEXT_PUBLIC_GA4_ID=                  # e.g. G-XXXXXXXXXX

# --- Admin dashboard (/admin) ---
# Both required to enable /admin. The password gates login; the secret signs the
# session cookie — make it a long random string (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Contact details shown on the page (used in header / footer / FAB) ---
NEXT_PUBLIC_CONTACT_PHONE=+91 95552 17077
NEXT_PUBLIC_WHATSAPP_NUMBER=919555219007
NEXT_PUBLIC_SITE_URL=http://localhost:3000
