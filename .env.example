# ── AnalytixLabs Classroom Landing Page — environment ───────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Supabase (lead storage) ---
# This app is isolated in its own schema inside a shared Supabase project.
# After running the migrations, expose the schema: Supabase → Settings → API →
# "Exposed schemas" → add the SUPABASE_SCHEMA value below.
NEXT_PUBLIC_SUPABASE_URL=            # https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=                # service_role OR new `sb_secret_…` key (SERVER ONLY)
# SUPABASE_SECRET_KEY=               # alias accepted if you use the new key naming
SUPABASE_SCHEMA=classroom_lp         # dedicated schema for this app's tables

# --- LeadSquared CRM (optional; skipped if LSQ_ACCESS/LSQ_SECRET blank) ---
LSQ_ACCESS=                          # LeadSquared access key
LSQ_SECRET=                          # LeadSquared secret key
LSQ_HOST=api-in21.leadsquared.com    # your LSQ region/host
LSQ_LEAD_SCORE_FIELD=mx_Lead_Score   # schema name of the lead-score field
LSQ_NOTES_FIELD_NAME=mx_Notes        # schema name of the notes field
LSQ_FBCLID_FIELD=mx_FBCLID           # schema name of the Meta click-id field
LSQ_CHAT_FIELD=mx_Chat_Transcript    # schema name of the Gemini transcript field

# --- Gemini (lead qualification chatbot + scoring) ---
# When unset, the qualification chat still runs but skips AI acks/scoring.
GEMINI_API_KEY=                      # Google Gemini API key (aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash        # optional; code defaults to gemini-2.5-flash

# --- Conversion tracking (all optional; tags are skipped if blank) ---
# Meta (Facebook) Pixel — fires PageView on load + Lead on successful submit.
NEXT_PUBLIC_META_PIXEL_ID=

# Google Ads — gtag config id (AW-XXXXXXXXX) + the conversion label for a lead.
NEXT_PUBLIC_GOOGLE_ADS_ID=           # e.g. AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=   # e.g. AbC-D_efGhIjKlmNoP (from the conversion action)

# Google Analytics 4 — fires page_view + a generate_lead event.
NEXT_PUBLIC_GA4_ID=                  # e.g. G-XXXXXXXXXX

# --- Admin dashboard (/admin) ---
# Both required to enable /admin. The password gates login; the secret signs the
# session cookie — make it a long random string (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Contact details shown on the page (used in header / footer / FAB) ---
NEXT_PUBLIC_CONTACT_PHONE=+91 95552 17077
NEXT_PUBLIC_WHATSAPP_NUMBER=919555217077
NEXT_PUBLIC_SITE_URL=http://localhost:3000
